# Environment Configuration Template
# Copy this file to .env and update with your actual settings

# ============================================
# APPLICATION SETTINGS
# ============================================

APP_NAME=SUZA Clearance System
APP_DEBUG=false
APP_ENV=production
APP_URL=http://localhost/rashidprojECT
APP_TIMEZONE=Africa/Dar_es_Salaam

# ============================================
# DATABASE CONFIGURATION
# ============================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=suza_clearance_system
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ============================================
# EMAIL CONFIGURATION
# ============================================

MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@suza.ac.tz
MAIL_FROM_NAME=SUZA Clearance System

# Optional: Use other mail services
# MAIL_DRIVER=sendmail
# MAIL_HOST=smtp.sendgrid.net
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================

SMS_ENABLED=false
SMS_PROVIDER=africastalking
SMS_API_KEY=your-api-key
SMS_API_USERNAME=your-username
SMS_SENDER_ID=SUZA

# ============================================
# SYSTEM CONFIGURATION
# ============================================

# Certificate expiry in days (0 for no expiry)
CERTIFICATE_EXPIRY_DAYS=365

# Maximum time for approval in days
MAX_APPROVAL_TIME_DAYS=14

# Enable QR code verification
ENABLE_QR_VERIFICATION=true

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable SMS notifications
ENABLE_SMS_NOTIFICATIONS=false

# Default sender email
DEFAULT_FROM_EMAIL=noreply@suza.ac.tz

# Organization name
ORGANIZATION_NAME=SUZA

# Organization logo URL
ORGANIZATION_LOGO_URL=/assets/images/suza-logo.png

# ============================================
# FILE UPLOAD PATHS
# ============================================

UPLOAD_CERTIFICATES_DIR=uploads/certificates/
UPLOAD_SIGNATURES_DIR=uploads/signatures/
UPLOAD_LOGOS_DIR=uploads/logos/
UPLOAD_DOCUMENTS_DIR=uploads/documents/

# Maximum file size in MB
MAX_UPLOAD_SIZE=10

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Session timeout in minutes
SESSION_TIMEOUT=60

# Password minimum length
PASSWORD_MIN_LENGTH=8

# Enable password reset feature
ENABLE_PASSWORD_RESET=true

# Password reset token expiry in hours
PASSWORD_RESET_EXPIRY=24

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION=15

# ============================================
# EMAIL QUEUE CONFIGURATION
# ============================================

# Number of emails to process per run
EMAIL_BATCH_SIZE=50

# Maximum email retry attempts
EMAIL_MAX_RETRIES=3

# Email queue cleanup: days to keep failed emails
EMAIL_CLEANUP_DAYS=30

# ============================================
# AUDIT LOGGING CONFIGURATION
# ============================================

# Retention period for audit logs in days
AUDIT_LOG_RETENTION_DAYS=90

# Enable detailed audit logging
ENABLE_DETAILED_AUDIT=true

# Log IP addresses
LOG_IP_ADDRESSES=true

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================

# Retention period for notifications in days
NOTIFICATION_RETENTION_DAYS=30

# Maximum notifications to return per request
MAX_NOTIFICATIONS_PER_PAGE=50

# ============================================
# WORKFLOW CONFIGURATION
# ============================================

# Default approval workflow type (sequential or parallel)
DEFAULT_WORKFLOW_TYPE=sequential

# Allow parallel approvals
ALLOW_PARALLEL_APPROVALS=false

# ============================================
# API CONFIGURATION
# ============================================

# Enable API access
API_ENABLED=true

# API rate limiting (requests per minute)
API_RATE_LIMIT=60

# API token expiry in hours
API_TOKEN_EXPIRY=24

# ============================================
# CACHE CONFIGURATION
# ============================================

CACHE_DRIVER=file
CACHE_PREFIX=suza_clearance_

# Cache expiry in minutes
CACHE_DEFAULT_TTL=300

# ============================================
# LOGGING CONFIGURATION
# ============================================

LOG_CHANNEL=single
LOG_LEVEL=warning
LOG_FILE=logs/app.log
LOG_MAX_FILES=10
LOG_MAX_SIZE=10240

# ============================================
# REPORT GENERATION
# ============================================

# Enable PDF report generation
ENABLE_PDF_REPORTS=true

# Report timezone
REPORT_TIMEZONE=Africa/Dar_es_Salaam

# ============================================
# ADVANCED FEATURES
# ============================================

# Enable certificate generation
ENABLE_CERTIFICATES=true

# Enable QR codes
ENABLE_QR_CODES=true

# QR code size
QR_CODE_SIZE=300

# Enable workflow engine
ENABLE_WORKFLOW_ENGINE=true

# Enable notification service
ENABLE_NOTIFICATIONS=true

# ============================================
# DEVELOPER SETTINGS
# ============================================

# Debug mode (disable in production)
DEBUG_MODE=false

# Show database queries in logs
LOG_DATABASE_QUERIES=false

# Show exception details
DISPLAY_EXCEPTIONS=false

# Test mode (for development only)
TEST_MODE=false

# ============================================
# EXTERNAL SERVICES (Optional)
# ============================================

# AWS Configuration (for S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# SendGrid Configuration (alternative email)
SENDGRID_API_KEY=

# Twilio Configuration (alternative SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Enable automatic backups
ENABLE_BACKUPS=true

# Backup frequency (daily, weekly, monthly)
BACKUP_FREQUENCY=daily

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup storage directory
BACKUP_DIRECTORY=backups/

# ============================================
# NOTES
# ============================================

# 1. For Gmail SMTP, use App Passwords, not your regular password
#    Generate at: https://myaccount.google.com/apppasswords
#
# 2. Create upload directories before deploying:
#    mkdir -p uploads/certificates uploads/signatures uploads/logos uploads/documents
#
# 3. Ensure proper file permissions:
#    chmod 755 uploads/
#    chmod 755 logs/
#
# 4. Never commit .env to version control
#    Add to .gitignore: .env
#
# 5. Keep .env.example updated with new variables
#    But do NOT include sensitive values in .env.example
#
# 6. Review all settings before production deployment
#
# 7. Test email configuration thoroughly
#    Use test email before deploying to users

# ============================================
# FEATURE FLAGS (Coming Soon)
# ============================================

# FEATURE_DIGITAL_SIGNATURES=false
# FEATURE_MOBILE_APP=false
# FEATURE_SMS_NOTIFICATIONS=false
# FEATURE_ADVANCED_ANALYTICS=false
# FEATURE_WORKFLOW_AUTOMATION=false
